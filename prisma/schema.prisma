generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String             @id @default(cuid())
  email                   String             @unique
  name                    String?
  avatar                  String?
  image                   String?
  emailVerified           DateTime?
  createdAt               DateTime           @default(now())
  workdayEnd              String             @default("18:00")
  workdayStart            String             @default("09:00")
  audioCheckpointsEnabled Boolean            @default(true)
  audioCuesEnabled        Boolean            @default(true)
  audioVolume             String             @default("HIGH")
  audioWarningEnabled     Boolean            @default(true)
  theme                   String             @default("LIGHT")
  journalUnlockTime       String             @default("20:00")
  accounts                Account[]
  contacts                Contact[]
  focusSessions           FocusSession[]
  journals                Journal[]
  projects                Project[]
  pushSubs                PushSubscription[]
  sessions                Session[]
  tasks                   Task[]
  aiMemories              AIMemory[]
  attachments             Attachment[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Contact {
  id                String     @id @default(cuid())
  userId            String
  stage             Stage      @default(LEAD)
  name              String
  phone             String?
  email             String?
  moneyValue        Decimal    @default(0) @db.Decimal(10, 2)
  priority          Priority   @default(MEDIUM)
  reminderAt        DateTime?
  notes             String?
  attachments       String[]
  tags              String[]
  source            String?
  followUpCount     Int        @default(0)
  lastContactedAt   DateTime?
  isArchived        Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  company           String?
  contactType       String?    @default("OTHER")
  interests         String[]
  relationshipScore Int        @default(50)
  linkedin          String?
  activities        Activity[]
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks             Task[]
  globalAttachments Attachment[]

  @@index([userId, stage])
  @@index([userId, reminderAt])
}

model Activity {
  id        String       @id @default(cuid())
  contactId String
  type      ActivityType
  content   String
  createdAt DateTime     @default(now())
  contact   Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id        String       @id @default(cuid())
  name      String
  color     String?
  userId    String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  isPinned  Boolean      @default(false)
  position  Float        @default(0)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks     Task[]
  columns   TaskColumn[]
  attachments Attachment[]

  @@index([userId])
}

model TaskColumn {
  id        String   @id @default(cuid())
  name      String
  position  Float
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  color     String?
  tasks     Task[]
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Task {
  id                       String         @id @default(cuid())
  title                    String
  description              String?
  isCompleted              Boolean        @default(false)
  dueDate                  DateTime?
  reminderAt               DateTime?
  priority                 TaskPriority   @default(NONE)
  isPinned                 Boolean        @default(false)
  position                 Float
  projectId                String
  columnId                 String?
  userId                   String
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  contactId                String?
  endTime                  DateTime?
  startTime                DateTime?
  taskType                 TaskType       @default(GENERAL)
  completedAt              DateTime?
  estimatedDurationMinutes Int?
  focusSessions            FocusSession[]
  subtasks                 Subtask[]
  column                   TaskColumn?    @relation(fields: [columnId], references: [id])
  contact                  Contact?       @relation(fields: [contactId], references: [id])
  project                  Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user                     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments              Attachment[]

  @@index([projectId])
  @@index([columnId])
  @@index([userId])
  @@index([dueDate])
  @@index([contactId])
}

model Subtask {
  id          String   @id @default(cuid())
  title       String
  isCompleted Boolean  @default(false)
  position    Float
  taskId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model FocusSession {
  id                  String   @id @default(cuid())
  taskId              String
  userId              String
  startTime           DateTime
  endTime             DateTime
  actualFocusDuration Int
  createdAt           DateTime @default(now())
  task                Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([taskId])
}

model Journal {
  id                String           @id @default(cuid())
  userId            String
  date              DateTime
  originalText      String
  quote             String
  productivityScore Int
  focusStreak       Int
  sticker           String
  insights          Json
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  content           Json?
  isFavorite        Boolean          @default(false)
  isPinned          Boolean          @default(false)
  tags              String[]
  subtitle          String?
  themeColor        String?
  musicMood         String?
  highlights        String[]
  attachments       Attachment[]
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  isFinalized       Boolean          @default(false)
  personalMemories  PersonalMemory[]
  versions          JournalVersion[]

  @@unique([userId, date])
  @@index([userId, date])
}

model PersonalMemory {
  id        String   @id @default(cuid())
  journalId String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  journal   Journal  @relation(fields: [journalId], references: [id], onDelete: Cascade)

  @@index([journalId])
}

model AIMemory {
  id                 String   @id @default(cuid())
  userId             String
  date               DateTime
  highlights         String[]
  achievements       String[]
  challenges         String[]
  lessons            String[]
  peopleMentioned    String[]
  projectsMentioned  String[]
  mood               String?
  moodScore          Int?
  productivityTrend  String?
  focusTrend         String?
  relationshipTrend  String?
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, date])
  @@index([userId, date])
}

model JournalVersion {
  id            String   @id @default(cuid())
  journalId     String
  versionNumber Int
  snapshot      Json
  createdBy     String
  createdAt     DateTime @default(now())
  journal       Journal  @relation(fields: [journalId], references: [id], onDelete: Cascade)

  @@index([journalId])
}

model Attachment {
  id          String   @id @default(cuid())
  userId      String
  journalId   String?
  taskId      String?
  projectId   String?
  contactId   String?
  type        String
  filename    String
  storagePath String
  mimeType    String
  size        Int?
  duration    Int?
  pages       Int?
  thumbnail   String?
  summary     String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  journal     Journal? @relation(fields: [journalId], references: [id], onDelete: Cascade)
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([journalId])
  @@index([taskId])
  @@index([projectId])
  @@index([contactId])
}

enum Stage {
  LEAD
  POTENTIAL
  CUSTOMER
  REJECTED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  STAGE_CHANGE
  SYSTEM
}

enum TaskPriority {
  NONE
  LOW
  MEDIUM
  HIGH
}

enum TaskType {
  GENERAL
  CRM
  MEETING
  DEEP_WORK
  HABIT
}
