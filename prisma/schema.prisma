generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String             @id @default(cuid())
  email         String             @unique
  name          String?
  avatar        String?
  image         String?
  emailVerified DateTime?
  workdayStart  String             @default("09:00")
  workdayEnd    String             @default("18:00")
  createdAt     DateTime           @default(now())
  accounts      Account[]
  contacts      Contact[]
  projects      Project[]
  pushSubs      PushSubscription[]
  sessions      Session[]
  tasks         Task[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Contact {
  id              String     @id @default(cuid())
  userId          String
  stage           Stage      @default(LEAD)
  name            String
  phone           String?
  email           String?

  company           String?
  linkedin          String?
  contactType       String? @default("OTHER")
  relationshipScore Int @default(50)
  interests         String[]

  moneyValue      Decimal    @default(0) @db.Decimal(10, 2)
  priority        Priority   @default(MEDIUM)
  reminderAt      DateTime?
  notes           String?
  attachments     String[]
  tags            String[]
  source          String?
  followUpCount   Int        @default(0)
  lastContactedAt DateTime?
  isArchived      Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  activities      Activity[]
  tasks           Task[]
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, stage])
  @@index([userId, reminderAt])
}

model Activity {
  id        String       @id @default(cuid())
  contactId String
  type      ActivityType
  content   String
  createdAt DateTime     @default(now())
  contact   Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id        String       @id @default(cuid())
  name      String
  color     String?
  userId    String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  isPinned  Boolean      @default(false)
  position  Float        @default(0)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks     Task[]
  columns   TaskColumn[]

  @@index([userId])
}

model TaskColumn {
  id        String   @id @default(cuid())
  name      String
  position  Float
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  isCompleted Boolean      @default(false)
  completedAt DateTime?
  dueDate     DateTime?
  reminderAt  DateTime?
  priority    TaskPriority @default(NONE)
  isPinned    Boolean      @default(false)
  position    Float
  projectId   String
  columnId    String?
  userId      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  startTime   DateTime?
  endTime     DateTime?
  taskType    TaskType     @default(GENERAL)
  subtasks    Subtask[]
  column      TaskColumn?  @relation(fields: [columnId], references: [id])
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId   String?
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([columnId])
  @@index([userId])
  @@index([dueDate])
  @@index([contactId])
}

model Subtask {
  id          String   @id @default(cuid())
  title       String
  isCompleted Boolean  @default(false)
  position    Float
  taskId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

enum Stage {
  LEAD
  POTENTIAL
  CUSTOMER
  REJECTED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  STAGE_CHANGE
  SYSTEM
}

enum TaskPriority {
  NONE
  LOW
  MEDIUM
  HIGH
}

enum TaskType {
  GENERAL
  CRM
  MEETING
  DEEP_WORK
  HABIT
}
